# Database (SQLite — the file is created automatically)
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
WEB_ORIGIN="http://localhost:5173"

# Auth secrets (change in production)
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_STATE_SECRET="change-me-oauth-state-secret"

# Encryption key for storing integration tokens (change in production)
ENCRYPTION_KEY="change-me-encryption-key"

# Mercado Pago OAuth
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_REDIRECT_URI="http://localhost:4000/api/integrations/mercadopago/callback"
